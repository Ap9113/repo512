@model ProductSelling.Models.Product
@{
    ViewData["Title"] = Model.Name;
}
<div class="row">
    <div class="col-md-6">
        <img src="@Model.ImageUrl" class="img-fluid" alt="@Model.Name" />
    </div>
    <div class="col-md-6">
        <h2>@Model.Name</h2>
        <p>@Model.Description</p>
        <h4 class="text-primary">$@Model.Price</h4>
        <form asp-controller="Cart" asp-action="Add" method="post">
            <input type="hidden" name="productId" value="@Model.Id" />
            <div class="form-group">
                <label>Quantity</label>
                <input type="number" name="quantity" value="1" class="form-control" min="1" />
            </div>
            <button type="submit" class="btn btn-success">Add to Cart</button>
            <a asp-action="Index" class="btn btn-secondary">Back to Products</a>
        </form>
    </div>
</div>